# .env.example
# Copy this to .env and fill in your values.
# .env is gitignored — never commit it.
#
#   cp .env.example .env

# Django secret key — generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-me-with-a-real-secret-key

# Debug mode — set to False in production
DEBUG=True

# Allowed hosts — comma separated (no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1

# Database URL — leave empty to use SQLite locally
# Render PostgreSQL format: postgres://user:password@host:port/dbname
DATABASE_URL=

# API key for Lambda to authenticate when POSTing readings
# Must match the key in Lambda's handler.py DJANGO_API_KEY variable
DJANGO_API_KEY=replace-me-with-a-strong-api-key

# Default device source identifier
DEVICE_SOURCE=pi-01
